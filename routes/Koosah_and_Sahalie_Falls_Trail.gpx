<gpx xmlns="http://www.topografix.com/GPX/1/1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="1.1" creator="AllTrails.com" xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd">
  <metadata>
    <name><![CDATA[Koosah and Sahalie Falls Trail]]></name>
    <desc><![CDATA[]]></desc>
    <link href="http://www.alltrails.com">
      <text>AllTrails, LLC</text>
    </link>
    <bounds minlat="44.34051" minlon="-122.00403" maxlat="44.35404" maxlon="-121.99595"/>
  </metadata>
  <wpt lat="44.3486575" lon="-121.9959533">
    <name><![CDATA[Sahalie Falls Parking Area Trailhead]]></name>
    <desc><![CDATA[Lots of free parking located here.  There are restrooms as well.]]></desc>
  </wpt>
  <wpt lat="44.3485808" lon="-121.9969726">
    <name><![CDATA[Sahalie Falls]]></name>
    <desc><![CDATA[Sahalie is a Chinook Jargon word meaning "high".  It is 73 foot tall falls.]]></desc>
  </wpt>
  <wpt lat="44.3435399" lon="-122.0004165">
    <name><![CDATA[Koosah Falls]]></name>
    <desc><![CDATA[Koosah is a Chinook Jargon word meaning "sky".  It is 64 feet high.]]></desc>
  </wpt>
  <wpt lat="44.3406204" lon="-122.0029292">
    <name><![CDATA[Carmen Reservoir]]></name>
    <desc><![CDATA[This very small reservoir (32 acres) is located at 3000 feet in elevation. Only non-motorized boats are allowed.]]></desc>
  </wpt>
  <wpt lat="44.3418058" lon="-122.0040751">
    <name><![CDATA[Join the McKenzie River Trail]]></name>
    <desc><![CDATA[Turn north back up river to continue the loop.]]></desc>
  </wpt>
  <wpt lat="44.3438008" lon="-122.001071">
    <name><![CDATA[Koosah Falls West Viewpoint]]></name>
    <desc><![CDATA[Here is a view of Koosah from the McKenzie River Trail side of the falls.]]></desc>
  </wpt>
  <wpt lat="44.3487419" lon="-121.9976377">
    <name><![CDATA[Sahalie Falls West Viewpoint]]></name>
    <desc><![CDATA[Here is a view of Sahalie Falls from the McKenzie River Trail side of the falls.]]></desc>
  </wpt>
  <wpt lat="44.3540508" lon="-121.9981527">
    <name><![CDATA[Bridge Over McKenzie]]></name>
    <desc><![CDATA[Cross over the McKenzie River on this bridge.  On the other side make sure you take the trail south.  The trail that heads north will take you to Clear Lake.]]></desc>
  </wpt>
  <trk>
    <name><![CDATA[Koosah and Sahalie Falls Trail]]></name>
    <src>AllTrails</src>
